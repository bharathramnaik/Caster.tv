{
  "id": "common-countdown",
  "name": "Countdown Timer",
  "category": "lower-third",
  "sport": "generic",
  "canvas": { "width": 400, "height": 140 },
  "elements": [
    {
      "id": "bg",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 400, "height": 140 },
      "style": { "fill": "#0f172a", "rx": 12, "opacity": 0.95 }
    },
    {
      "id": "progress-ring-bg",
      "type": "circle",
      "position": { "x": 20, "y": 20, "width": 100, "height": 100 },
      "style": { "fill": "none", "stroke": "#1e293b", "strokeWidth": 6 }
    },
    {
      "id": "progress-ring",
      "type": "circle",
      "position": { "x": 20, "y": 20, "width": 100, "height": 100 },
      "style": { "fill": "none", "stroke": "#f59e0b", "strokeWidth": 6, "strokeDasharray": "283", "strokeLinecap": "round", "transform-origin": "center", "animation": "rotate 4s linear infinite" },
      "binding": "progress"
    },
    {
      "id": "timer-text",
      "type": "text",
      "position": { "x": 20, "y": 42, "width": 100, "height": 56 },
      "style": { "fontSize": "36px", "fontWeight": "800", "color": "#ffffff", "fontFamily": "monospace", "textAlign": "center" },
      "binding": "timeRemaining"
    },
    {
      "id": "event-name",
      "type": "text",
      "position": { "x": 135, "y": 25, "width": 250, "height": 35 },
      "style": { "fontSize": "22px", "fontWeight": "700", "color": "#ffffff", "fontFamily": "Outfit" },
      "binding": "eventName"
    },
    {
      "id": "event-detail",
      "type": "text",
      "position": { "x": 135, "y": 60, "width": 250, "height": 22 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.6)", "fontFamily": "Inter" },
      "binding": "eventDetail"
    },
    {
      "id": "status-text",
      "type": "text",
      "position": { "x": 135, "y": 88, "width": 250, "height": 20 },
      "style": { "fontSize": "12px", "fontWeight": "600", "color": "#f59e0b", "fontFamily": "Inter", "textTransform": "uppercase" },
      "binding": "status"
    }
  ],
  "animation": {
    "in": { "type": "scale", "from": 0.8, "to": 1, "duration": 400 },
    "out": { "type": "fade", "from": 1, "to": 0, "duration": 300 }
  }
}