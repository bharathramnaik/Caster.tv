{
  "id": "common-breaking-news",
  "name": "Breaking News",
  "category": "lower-third",
  "sport": "generic",
  "canvas": { "width": 800, "height": 120 },
  "elements": [
    {
      "id": "bg-main",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 800, "height": 120 },
      "style": { "fill": "#1a1a2e", "rx": 0, "opacity": 0.95 }
    },
    {
      "id": "bg-red-bar",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 800, "height": 8 },
      "style": { "fill": "#dc2626" }
    },
    {
      "id": "pulse-indicator",
      "type": "circle",
      "position": { "x": 20, "y": 28, "width": 12, "height": 12 },
      "style": { "fill": "#dc2626", "animation": "pulse 1.5s ease-in-out infinite" }
    },
    {
      "id": "breaking-label",
      "type": "text",
      "position": { "x": 40, "y": 20, "width": 180, "height": 30 },
      "style": { "fontSize": "18px", "fontWeight": "800", "color": "#dc2626", "fontFamily": "Outfit", "textTransform": "uppercase", "letterSpacing": "2px" },
      "static": "BREAKING NEWS"
    },
    {
      "id": "headline-text",
      "type": "text",
      "position": { "x": 20, "y": 58, "width": 760, "height": 35 },
      "style": { "fontSize": "20px", "fontWeight": "600", "color": "#ffffff", "fontFamily": "Inter" },
      "binding": "headline"
    },
    {
      "id": "source-text",
      "type": "text",
      "position": { "x": 20, "y": 95, "width": 760, "height": 20 },
      "style": { "fontSize": "13px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "fontFamily": "Inter" },
      "binding": "source"
    }
  ],
  "animation": {
    "in": { "type": "slide", "direction": "top", "duration": 500 },
    "out": { "type": "slide", "direction": "top", "duration": 400 }
  }
}