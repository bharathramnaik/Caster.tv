{
  "id": "common-sponsor-band",
  "name": "Sponsor Band",
  "category": "lower-third",
  "sport": "generic",
  "canvas": { "width": 600, "height": 90 },
  "elements": [
    {
      "id": "bg",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 600, "height": 90 },
      "style": { "fill": "#0f172a", "rx": 8, "opacity": 0.95 }
    },
    {
      "id": "sponsor-badge",
      "type": "rect",
      "position": { "x": 10, "y": 10, "width": 80, "height": 22 },
      "style": { "fill": "#f59e0b", "rx": 4 }
    },
    {
      "id": "sponsor-badge-text",
      "type": "text",
      "position": { "x": 10, "y": 12, "width": 80, "height": 18 },
      "style": { "fontSize": "11px", "fontWeight": "700", "color": "#000000", "fontFamily": "Outfit", "textTransform": "uppercase", "textAlign": "center" },
      "static": "SPONSOR"
    },
    {
      "id": "logo-placeholder",
      "type": "rect",
      "position": { "x": 120, "y": 18, "width": 54, "height": 54 },
      "style": { "fill": "#1e293b", "rx": 8, "stroke": "#334155", "strokeWidth": 1 }
    },
    {
      "id": "logo-text",
      "type": "text",
      "position": { "x": 120, "y": 32, "width": 54, "height": 26 },
      "style": { "fontSize": "10px", "fontWeight": "500", "color": "#64748b", "fontFamily": "Inter", "textAlign": "center" },
      "static": "LOGO"
    },
    {
      "id": "sponsor-name",
      "type": "text",
      "position": { "x": 190, "y": 14, "width": 390, "height": 30 },
      "style": { "fontSize": "22px", "fontWeight": "700", "color": "#ffffff", "fontFamily": "Outfit" },
      "binding": "sponsor.name"
    },
    {
      "id": "sponsor-tagline",
      "type": "text",
      "position": { "x": 190, "y": 42, "width": 390, "height": 22 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.6)", "fontFamily": "Inter" },
      "binding": "sponsor.tagline"
    },
    {
      "id": "cta-text",
      "type": "text",
      "position": { "x": 190, "y": 66, "width": 390, "height": 18 },
      "style": { "fontSize": "12px", "fontWeight": "600", "color": "#f59e0b", "fontFamily": "Inter" },
      "binding": "sponsor.cta"
    }
  ],
  "animation": {
    "in": { "type": "slide", "direction": "left", "duration": 500 },
    "out": { "type": "slide", "direction": "left", "duration": 400 }
  }
}