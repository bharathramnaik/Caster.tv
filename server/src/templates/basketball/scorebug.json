{
  "id": "basketball-scorebug",
  "name": "Basketball Score Bug",
  "category": "scoreboard",
  "sport": "basketball",
  "canvas": { "width": 520, "height": 70 },
  "elements": [
    {
      "id": "bg",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 520, "height": 70 },
      "style": { "fill": "#1a1a2e", "rx": 8, "opacity": 0.95 }
    },
    {
      "id": "quarter-badge",
      "type": "rect",
      "position": { "x": 210, "y": 0, "width": 100, "height": 24 },
      "style": { "fill": "#f59e0b", "rx": 4 }
    },
    {
      "id": "quarter-text",
      "type": "text",
      "position": { "x": 210, "y": 3, "width": 100, "height": 18 },
      "style": { "fontSize": "12px", "fontWeight": "700", "color": "#000000", "fontFamily": "Outfit", "textAlign": "center", "textTransform": "uppercase" },
      "binding": "quarter"
    },
    {
      "id": "home-color",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 6, "height": 70 },
      "style": { "fill": "#1d4ed8" },
      "binding": "homeTeam.color"
    },
    {
      "id": "home-logo",
      "type": "image",
      "position": { "x": 14, "y": 10, "width": 50, "height": 50 },
      "binding": "homeTeam.logo"
    },
    {
      "id": "home-name",
      "type": "text",
      "position": { "x": 70, "y": 10, "width": 120, "height": 22 },
      "style": { "fontSize": "15px", "fontWeight": "700", "color": "#ffffff", "fontFamily": "Outfit" },
      "binding": "homeTeam.name"
    },
    {
      "id": "home-score",
      "type": "text",
      "position": { "x": 70, "y": 32, "width": 60, "height": 34 },
      "style": { "fontSize": "34px", "fontWeight": "800", "color": "#ffffff", "fontFamily": "monospace" },
      "binding": "homeTeam.score"
    },
    {
      "id": "home-fouls",
      "type": "text",
      "position": { "x": 140, "y": 40, "width": 50, "height": 18 },
      "style": { "fontSize": "11px", "fontWeight": "600", "color": "rgba(255,255,255,0.5)", "fontFamily": "Inter" },
      "binding": "homeTeam.fouls"
    },
    {
      "id": "separator",
      "type": "text",
      "position": { "x": 245, "y": 30, "width": 30, "height": 36 },
      "style": { "fontSize": "28px", "fontWeight": "300", "color": "rgba(255,255,255,0.3)", "fontFamily": "monospace", "textAlign": "center" },
      "static": ":"
    },
    {
      "id": "away-color",
      "type": "rect",
      "position": { "x": 514, "y": 0, "width": 6, "height": 70 },
      "style": { "fill": "#dc2626" },
      "binding": "awayTeam.color"
    },
    {
      "id": "away-logo",
      "type": "image",
      "position": { "x": 456, "y": 10, "width": 50, "height": 50 },
      "binding": "awayTeam.logo"
    },
    {
      "id": "away-name",
      "type": "text",
      "position": { "x": 330, "y": 10, "width": 120, "height": 22 },
      "style": { "fontSize": "15px", "fontWeight": "700", "color": "#ffffff", "fontFamily": "Outfit", "textAlign": "right" },
      "binding": "awayTeam.name"
    },
    {
      "id": "away-score",
      "type": "text",
      "position": { "x": 390, "y": 32, "width": 60, "height": 34 },
      "style": { "fontSize": "34px", "fontWeight": "800", "color": "#ffffff", "fontFamily": "monospace", "textAlign": "right" },
      "binding": "awayTeam.score"
    },
    {
      "id": "away-fouls",
      "type": "text",
      "position": { "x": 330, "y": 40, "width": 50, "height": 18 },
      "style": { "fontSize": "11px", "fontWeight": "600", "color": "rgba(255,255,255,0.5)", "fontFamily": "Inter", "textAlign": "right" },
      "binding": "awayTeam.fouls"
    },
    {
      "id": "game-clock",
      "type": "text",
      "position": { "x": 210, "y": 32, "width": 100, "height": 32 },
      "style": { "fontSize": "26px", "fontWeight": "800", "color": "#ffffff", "fontFamily": "monospace", "textAlign": "center" },
      "binding": "gameClock"
    }
  ],
  "animation": {
    "in": { "type": "slide", "direction": "top", "duration": 400 },
    "out": { "type": "slide", "direction": "top", "duration": 300 }
  }
}