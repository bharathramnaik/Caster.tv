{
  "id": "cricket-player-card",
  "name": "Cricket Player Card",
  "category": "player",
  "sport": "cricket",
  "canvas": { "width": 1920, "height": 1080 },
  "elements": [
    {
      "id": "background-overlay",
      "type": "shape",
      "position": { "x": 0, "y": 0, "width": 1920, "height": 1080 },
      "style": { "background": "linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 100%)" }
    },
    {
      "id": "team-color-bar",
      "type": "shape",
      "position": { "x": 0, "y": 0, "width": 1920, "height": 8 },
      "style": { "background": "{{player.team.primaryColor}}" }
    },
    {
      "id": "player-photo-frame",
      "type": "shape",
      "position": { "x": 100, "y": 150, "width": 400, "height": 500 },
      "style": {
        "background": "{{player.team.primaryColor}}",
        "borderRadius": "8px",
        "overflow": "hidden",
        "boxShadow": "0 8px 32px rgba(0,0,0,0.4)"
      }
    },
    {
      "id": "player-photo",
      "type": "image",
      "position": { "x": 104, "y": 154, "width": 392, "height": 492 },
      "style": { "objectFit": "cover" },
      "binding": "player.photo"
    },
    {
      "id": "player-jersey-number",
      "type": "text",
      "position": { "x": 100, "y": 660, "width": 400, "height": 80 },
      "style": {
        "fontSize": "72px",
        "fontWeight": "900",
        "color": "{{player.team.primaryColor}}",
        "fontFamily": "Teko",
        "textShadow": "2px 2px 4px rgba(0,0,0,0.3)",
        "textAlign": "center"
      },
      "binding": "player.jerseyNumber"
    },
    {
      "id": "player-info-panel",
      "type": "shape",
      "position": { "x": 560, "y": 150, "width": 800, "height": 600 },
      "style": { "background": "rgba(255,255,255,0.05)", "borderRadius": "12px" }
    },
    {
      "id": "player-name",
      "type": "text",
      "position": { "x": 600, "y": 180, "width": 720, "height": 60 },
      "style": { "fontSize": "48px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "player.name"
    },
    {
      "id": "player-role",
      "type": "text",
      "position": { "x": 600, "y": 240, "width": 300, "height": 35 },
      "style": { "fontSize": "22px", "fontWeight": "600", "color": "{{player.team.primaryColor}}", "textTransform": "uppercase" },
      "binding": "player.role"
    },
    {
      "id": "team-name-label",
      "type": "text",
      "position": { "x": 600, "y": 280, "width": 300, "height": 30 },
      "style": { "fontSize": "18px", "fontWeight": "500", "color": "rgba(255,255,255,0.6)" },
      "binding": "player.team.name"
    },
    {
      "id": "stats-divider",
      "type": "shape",
      "position": { "x": 600, "y": 330, "width": 720, "height": 2 },
      "style": { "background": "rgba(255,255,255,0.1)" }
    },
    {
      "id": "stats-label",
      "type": "text",
      "position": { "x": 600, "y": 350, "width": 200, "height": 30 },
      "style": { "fontSize": "14px", "fontWeight": "600", "color": "rgba(255,255,255,0.4)", "textTransform": "uppercase", "letterSpacing": "2px" },
      "literal": "Match Statistics"
    },
    {
      "id": "stat-1-label",
      "type": "text",
      "position": { "x": 600, "y": 400, "width": 160, "height": 25 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "textTransform": "uppercase" },
      "binding": "stats.stat1.label"
    },
    {
      "id": "stat-1-value",
      "type": "text",
      "position": { "x": 600, "y": 425, "width": 160, "height": 50 },
      "style": { "fontSize": "40px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "stats.stat1.value"
    },
    {
      "id": "stat-2-label",
      "type": "text",
      "position": { "x": 780, "y": 400, "width": 160, "height": 25 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "textTransform": "uppercase" },
      "binding": "stats.stat2.label"
    },
    {
      "id": "stat-2-value",
      "type": "text",
      "position": { "x": 780, "y": 425, "width": 160, "height": 50 },
      "style": { "fontSize": "40px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "stats.stat2.value"
    },
    {
      "id": "stat-3-label",
      "type": "text",
      "position": { "x": 960, "y": 400, "width": 160, "height": 25 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "textTransform": "uppercase" },
      "binding": "stats.stat3.label"
    },
    {
      "id": "stat-3-value",
      "type": "text",
      "position": { "x": 960, "y": 425, "width": 160, "height": 50 },
      "style": { "fontSize": "40px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "stats.stat3.value"
    },
    {
      "id": "stat-4-label",
      "type": "text",
      "position": { "x": 1140, "y": 400, "width": 160, "height": 25 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "textTransform": "uppercase" },
      "binding": "stats.stat4.label"
    },
    {
      "id": "stat-4-value",
      "type": "text",
      "position": { "x": 1140, "y": 425, "width": 160, "height": 50 },
      "style": { "fontSize": "40px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "stats.stat4.value"
    },
    {
      "id": "ball-by-ball-divider",
      "type": "shape",
      "position": { "x": 600, "y": 510, "width": 720, "height": 2 },
      "style": { "background": "rgba(255,255,255,0.1)" }
    },
    {
      "id": "bpb-label",
      "type": "text",
      "position": { "x": 600, "y": 530, "width": 200, "height": 30 },
      "style": { "fontSize": "14px", "fontWeight": "600", "color": "rgba(255,255,255,0.4)", "textTransform": "uppercase", "letterSpacing": "2px" },
      "literal": "This Over"
    },
    {
      "id": "ball-1",
      "type": "shape",
      "position": { "x": 600, "y": 575, "width": 48, "height": 48 },
      "style": { "borderRadius": "50%", "background": "{{ballByBall[0].color}}", "display": "flex", "alignItems": "center", "justifyContent": "center" },
      "binding": "ballByBall[0]"
    },
    {
      "id": "ball-2",
      "type": "shape",
      "position": { "x": 660, "y": 575, "width": 48, "height": 48 },
      "style": { "borderRadius": "50%", "background": "{{ballByBall[1].color}}", "display": "flex", "alignItems": "center", "justifyContent": "center" },
      "binding": "ballByBall[1]"
    },
    {
      "id": "ball-3",
      "type": "shape",
      "position": { "x": 720, "y": 575, "width": 48, "height": 48 },
      "style": { "borderRadius": "50%", "background": "{{ballByBall[2].color}}", "display": "flex", "alignItems": "center", "justifyContent": "center" },
      "binding": "ballByBall[2]"
    },
    {
      "id": "ball-4",
      "type": "shape",
      "position": { "x": 780, "y": 575, "width": 48, "height": 48 },
      "style": { "borderRadius": "50%", "background": "{{ballByBall[3].color}}", "display": "flex", "alignItems": "center", "justifyContent": "center" },
      "binding": "ballByBall[3]"
    },
    {
      "id": "ball-5",
      "type": "shape",
      "position": { "x": 840, "y": 575, "width": 48, "height": 48 },
      "style": { "borderRadius": "50%", "background": "{{ballByBall[4].color}}", "display": "flex", "alignItems": "center", "justifyContent": "center" },
      "binding": "ballByBall[4]"
    },
    {
      "id": "ball-6",
      "type": "shape",
      "position": { "x": 900, "y": 575, "width": 48, "height": 48 },
      "style": { "borderRadius": "50%", "background": "{{ballByBall[5].color}}", "display": "flex", "alignItems": "center", "justifyContent": "center" },
      "binding": "ballByBall[5]"
    },
    {
      "id": "team-logo",
      "type": "shape",
      "position": { "x": 1400, "y": 800, "width": 200, "height": 200 },
      "style": { "background": "{{player.team.primaryColor}}", "borderRadius": "50%", "opacity": 0.15 }
    }
  ],
  "animation": {
    "enter": "scale-in-fade",
    "exit": "scale-out-fade",
    "duration": 0.8,
    "stagger": 0.03
  }
}
