{
  "id": "cricket-scoreboard",
  "name": "Cricket Scoreboard",
  "category": "scoreboard",
  "sport": "cricket",
  "canvas": { "width": 1920, "height": 150 },
  "elements": [
    {
      "id": "batting-team-logo",
      "type": "shape",
      "position": { "x": 0, "y": 0, "width": 100, "height": 150 },
      "style": { "background": "{{battingTeam.primaryColor}}" },
      "binding": "battingTeam"
    },
    {
      "id": "batting-team-name",
      "type": "text",
      "position": { "x": 110, "y": 20, "width": 150, "height": 40 },
      "style": { "fontSize": "24px", "fontWeight": "700", "color": "#fff" },
      "binding": "battingTeam.short"
    },
    {
      "id": "striker-name",
      "type": "text",
      "position": { "x": 110, "y": 60, "width": 150, "height": 30 },
      "style": { "fontSize": "20px", "fontWeight": "600", "color": "#fff" },
      "binding": "striker.name"
    },
    {
      "id": "striker-runs",
      "type": "text",
      "position": { "x": 270, "y": 60, "width": 40, "height": 30 },
      "style": { "fontSize": "20px", "fontWeight": "700", "color": "#E3B23C" },
      "binding": "striker.runs"
    },
    {
      "id": "striker-balls",
      "type": "text",
      "position": { "x": 320, "y": 60, "width": 40, "height": 30 },
      "style": { "fontSize": "18px", "fontWeight": "500", "color": "rgba(255,255,255,0.6)" },
      "binding": "striker.balls"
    },
    {
      "id": "non-striker-name",
      "type": "text",
      "position": { "x": 110, "y": 95, "width": 150, "height": 30 },
      "style": { "fontSize": "18px", "fontWeight": "500", "color": "rgba(255,255,255,0.7)" },
      "binding": "nonStriker.name"
    },
    {
      "id": "non-striker-runs",
      "type": "text",
      "position": { "x": 270, "y": 95, "width": 40, "height": 30 },
      "style": { "fontSize": "18px", "fontWeight": "600", "color": "rgba(255,255,255,0.6)" },
      "binding": "nonStriker.runs"
    },
    {
      "id": "non-striker-balls",
      "type": "text",
      "position": { "x": 320, "y": 95, "width": 40, "height": 30 },
      "style": { "fontSize": "16px", "fontWeight": "500", "color": "rgba(255,255,255,0.4)" },
      "binding": "nonStriker.balls"
    },
    {
      "id": "score-box",
      "type": "shape",
      "position": { "x": 500, "y": 20, "width": 200, "height": 110 },
      "style": { "background": "#c0392b", "borderRadius": "4px", "boxShadow": "0 2px 8px rgba(192,57,43,0.4)" }
    },
    {
      "id": "score-runs",
      "type": "text",
      "position": { "x": 520, "y": 30, "width": 80, "height": 60 },
      "style": { "fontSize": "56px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "innings.runs"
    },
    {
      "id": "score-separator",
      "type": "text",
      "position": { "x": 600, "y": 40, "width": 20, "height": 40 },
      "style": { "fontSize": "44px", "fontWeight": "400", "color": "rgba(255,255,255,0.6)" },
      "literal": "-"
    },
    {
      "id": "score-wickets",
      "type": "text",
      "position": { "x": 620, "y": 30, "width": 80, "height": 60 },
      "style": { "fontSize": "56px", "fontWeight": "800", "color": "#fff", "fontFamily": "Teko" },
      "binding": "innings.wickets"
    },
    {
      "id": "overs-text",
      "type": "text",
      "position": { "x": 520, "y": 100, "width": 180, "height": 25 },
      "style": { "fontSize": "18px", "fontWeight": "600", "color": "rgba(255,255,255,0.8)" },
      "binding": "{{innings.overs}}.{{innings.balls}} OVER"
    },
    {
      "id": "run-rate-box",
      "type": "shape",
      "position": { "x": 720, "y": 20, "width": 120, "height": 110 },
      "style": { "background": "rgba(255,255,255,0.1)", "borderRadius": "4px" }
    },
    {
      "id": "run-rate-label",
      "type": "text",
      "position": { "x": 730, "y": 30, "width": 100, "height": 20 },
      "style": { "fontSize": "12px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "textTransform": "uppercase" },
      "literal": "Run Rate"
    },
    {
      "id": "run-rate-value",
      "type": "text",
      "position": { "x": 730, "y": 55, "width": 100, "height": 40 },
      "style": { "fontSize": "32px", "fontWeight": "700", "color": "#fff", "fontFamily": "Teko" },
      "binding": "innings.runRate"
    },
    {
      "id": "bowler-section",
      "type": "shape",
      "position": { "x": 900, "y": 20, "width": 300, "height": 110 },
      "style": { "background": "rgba(0,0,0,0.3)", "borderRadius": "4px" }
    },
    {
      "id": "bowler-label",
      "type": "text",
      "position": { "x": 910, "y": 25, "width": 100, "height": 20 },
      "style": { "fontSize": "12px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)", "textTransform": "uppercase" },
      "literal": "Bowler"
    },
    {
      "id": "bowler-name",
      "type": "text",
      "position": { "x": 910, "y": 45, "width": 280, "height": 30 },
      "style": { "fontSize": "22px", "fontWeight": "700", "color": "#fff" },
      "binding": "bowler.name"
    },
    {
      "id": "bowler-figures",
      "type": "text",
      "position": { "x": 910, "y": 80, "width": 150, "height": 25 },
      "style": { "fontSize": "20px", "fontWeight": "600", "color": "#E3B23C" },
      "binding": "{{bowler.wickets}}/{{bowler.runs}} ({{bowler.overs}}.{{bowler.balls}})"
    },
    {
      "id": "bowler-economy",
      "type": "text",
      "position": { "x": 1070, "y": 80, "width": 80, "height": 25 },
      "style": { "fontSize": "16px", "fontWeight": "500", "color": "rgba(255,255,255,0.6)" },
      "binding": "Econ: {{bowler.economy}}"
    },
    {
      "id": "target-box",
      "type": "shape",
      "position": { "x": 1250, "y": 20, "width": 150, "height": 50 },
      "style": { "background": "#27ae60", "borderRadius": "4px" },
      "condition": "isChasing"
    },
    {
      "id": "target-label",
      "type": "text",
      "position": { "x": 1260, "y": 25, "width": 130, "height": 20 },
      "style": { "fontSize": "12px", "fontWeight": "500", "color": "rgba(255,255,255,0.7)" },
      "literal": "TARGET",
      "condition": "isChasing"
    },
    {
      "id": "target-value",
      "type": "text",
      "position": { "x": 1260, "y": 42, "width": 130, "height": 25 },
      "style": { "fontSize": "22px", "fontWeight": "700", "color": "#fff" },
      "binding": "innings.target",
      "condition": "isChasing"
    },
    {
      "id": "required-rr",
      "type": "text",
      "position": { "x": 1260, "y": 80, "width": 150, "height": 25 },
      "style": { "fontSize": "16px", "fontWeight": "500", "color": "rgba(255,255,255,0.6)" },
      "binding": "Req RR: {{innings.requiredRunRate}}",
      "condition": "isChasing"
    },
    {
      "id": "balls-remaining",
      "type": "text",
      "position": { "x": 1260, "y": 105, "width": 150, "height": 20 },
      "style": { "fontSize": "14px", "fontWeight": "500", "color": "rgba(255,255,255,0.5)" },
      "binding": "Need {{innings.runsNeeded}} from {{innings.ballsRemaining}} balls",
      "condition": "isChasing"
    },
    {
      "id": "bowling-team-logo",
      "type": "shape",
      "position": { "x": 1820, "y": 0, "width": 100, "height": 150 },
      "style": { "background": "{{bowlingTeam.primaryColor}}" },
      "binding": "bowlingTeam"
    }
  ],
  "animation": {
    "enter": "slide-in-bottom",
    "exit": "slide-out-bottom",
    "duration": 0.5,
    "stagger": 0.05
  }
}
