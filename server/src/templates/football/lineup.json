{
  "id": "football-lineup",
  "name": "Football Team Lineup",
  "category": "lineup",
  "sport": "football",
  "canvas": { "width": 480, "height": 560 },
  "animation": {
    "in": { "type": "fade", "duration": 700 },
    "out": { "type": "fade", "duration": 400 }
  },
  "elements": [
    {
      "id": "background",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 480, "height": 560 },
      "style": { "fill": "#064e3b", "rx": 12, "opacity": 0.97 }
    },
    {
      "id": "header-bg",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 480, "height": 50 },
      "style": { "fill": "#022c22", "rx": 12 }
    },
    {
      "id": "team-name",
      "type": "text",
      "position": { "x": 0, "y": 12, "width": 300, "height": 26 },
      "style": { "fontSize": "18px", "fontWeight": "700", "color": "#fff", "fontFamily": "sans-serif", "textAlign": "left" },
      "binding": "team.name"
    },
    {
      "id": "formation",
      "type": "text",
      "position": { "x": 320, "y": 12, "width": 150, "height": 26 },
      "style": { "fontSize": "16px", "fontWeight": "600", "color": "#34d399", "fontFamily": "monospace", "textAlign": "right" },
      "binding": "team.formation"
    },
    {
      "id": "field-outline",
