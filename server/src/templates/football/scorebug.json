{
  "id": "football-scorebug",
  "name": "Football Score Bug",
  "category": "scoreboard",
  "sport": "football",
  "canvas": { "width": 400, "height": 80 },
  "animation": {
    "in": { "type": "slide", "direction": "left", "duration": 600 },
    "out": { "type": "slide", "direction": "left", "duration": 400 }
  },
  "elements": [
    {
      "id": "background",
      "type": "rect",
      "position": { "x": 0, "y": 0, "width": 400, "height": 80 },
      "style": { "fill": "#1a1a2e", "rx": 8, "opacity": 0.95 }
    },
    {
      "id": "home-logo",
      "type": "image",
      "position": { "x": 5, "y": 10, "width": 60, "height": 60 },
      "binding": "homeTeam.logo"
    },
    {
      "id": "home-name",
      "type": "text",
      "position": { "x": 70, "y": 12, "width": 100, "height": 25 },
      "style": { "fontSize": "16px", "fontWeight": "700", "color": "#fff", "fontFamily": "sans-serif" },
      "binding": "homeTeam.name"
    },
    {
      "id": "home-score",
      "type": "text",
      "position": { "x": 70, "y": 38, "width": 50, "height": 35 },
      "style": { "fontSize": "32px", "fontWeight": "800", "color": "#fff", "fontFamily": "monospace" },
      "binding": "homeTeam.score"
    },
    {
      "id": "time-display",
      "type": "text",
      "position": { "x": 170, "y": 20, "width": 60, "height": 40 },
      "style": { "fontSize": "22px", "fontWeight": "700", "color": "#4ade80", "fontFamily": "monospace", "textAlign": "center" },
      "binding": "matchTime"
    },
    {
      "id": "half-indicator",
      "type": "text",
      "position": { "x": 170, "y": 50, "width": 60, "height": 20 },
      "style": { "fontSize": "10px", "fontWeight": "600", "color": "#94a3b8", "fontFamily": "sans-serif", "textAlign": "center", "textTransform": "uppercase" },
      "binding": "matchHalf"
    },
    {
      "id": "away-score",
      "type": "text",
      "position": { "x": 280, "y": 38, "width": 50, "height": 35 },
      "style": { "fontSize": "32px", "fontWeight": "800", "color": "#fff", "fontFamily": "monospace", "textAlign": "right" },
      "binding": "awayTeam.score"
    },
    {
      "id": "away-name",
      "type": "text",
      "position": { "x": 280, "y": 12, "width": 100, "height": 25 },
      "style": { "fontSize": "16px", "fontWeight": "700", "color": "#fff", "fontFamily": "sans-serif", "textAlign": "right" },
      "binding": "awayTeam.name"
    },
    {
      "id": "away-logo",
      "type": "image",
      "position": { "x": 385, "y": 10, "width": 60, "height": 60 },
      "binding": "awayTeam.logo"
    }
  ]
}
