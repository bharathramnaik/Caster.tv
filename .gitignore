# ═══════════════════════════════════════════════════════════════
# BroadcastStudio - .gitignore
# Comprehensive ignore rules for Node.js/React/TypeScript project
# ═══════════════════════════════════════════════════════════════

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment Variables ────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Runtime Data ─────────────────────────────────────────────
server/data/store.json
server/data/authStore.json
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing ──────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── IDEs & Editors ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Temporary Files ──────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp

# ── Docker ───────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ── Security ─────────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt

# ── Exports (generated) ─────────────────────────────────────
server/exports/
*.html
!client/dist/**/*.html

# ── Database ─────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Misc ─────────────────────────────────────────────────────
*.tgz
*.tar.gz
.cache/
